flowchart LR
    A["PQID row metadata<br/>149 documented fields"]

    A --> B["Provenance<br/>source URL, repo, file path, anchors, hashes"]
    A --> C["Repository context<br/>topics, organization flag"]
    A --> D["Execution and validation<br/>status, materialized circuit, OpenQASM, failure class"]
    A --> E["Circuit structure<br/>qubits, gates, depth, topology, measurements"]
    A --> F["Gate-set and complexity<br/>Clifford/T, rotations, entanglement, parameterization"]
    A --> G["Benchmark readiness<br/>n/7 and n/8 checks, tiers, cleaning flags"]
    A --> H["Metadata-design overlay<br/>release, split, evidence, stance, governance"]
    A --> I["Instruction generation<br/>seed role, prompt type, model, template, lineage"]
    A --> J["Semantic metrics<br/>BERTScore, sentence similarity, BLEU, ROUGE-L, edit distance"]
    A --> K["Release metadata<br/>license category, release bucket, export profile"]

